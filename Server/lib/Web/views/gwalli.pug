extends layout

block Subject
	title 끄투닷플러스 관리 페이지

block JS
	script(type="text/javascript", src="/js/in_admin.min.js")
	
block Middle
	fieldset
		legend 자격
		input#db-password(type='password', placeholder='암호')
		input#db-lang(placeholder='테이블')
	fieldset
		legend 상점 DB 다루기
		div
			input#shop-word(placeholder='품목')
			button#shop-go 조회
			button#shop-hide 숨기기
			div
				table
					thead: tr
						td #
						td cost
						td hit
						td term
						td group
						td updatedAt
						td options
						td name_ko_KR
						td desc_ko_KR
						td name_en_US
						td desc_en_US
					tbody#shop-data
			button#shop-add 추가
			button#shop-apply 적용
	fieldset
		legend 유저 프로필 다루기
		div
			input#user-id(placeholder='ID')
			input#user-nick(placeholder='초기 닉네임')
			button#user-go 조회
			div
				table
					thead: tr
						td ID
						td 핑
						td 전적
						td 인벤토리
						td 착용 중인 아이템
						td 소개 한마디
						td 서버
						td 최근 로그인
						td 정지 사유
						td 친구
					tbody#user-data
			button#user-apply 적용
	fieldset
		legend 유저 감시하기
		div
			input#gamsi-id(placeholder='ID (,로 구분)')
			button#gamsi-go 감시
			div
				table
					thead: tr
						td #
						td 닉네임
						td 서버
					tbody#gamsi-data
	fieldset
		legend 단어 수정하기
		div
			input#db-word(placeholder='수정할 단어를 입력하세요.')
			button#db-go 조회
			div#word-data
				div#wd-id
				input#wd-flag
				table
					thead: tr
						td #
						td type
						td theme
						td mean
						td 행동
					tbody#wd-data
			div#word-flag
			div#word-hit
			button#word-add 추가
			button#db-apply 적용
	fieldset(style='margin-bottom: 100px;')
		legend 단어 추가하기
		div
			input#db-theme(placeholder='주제 코드를 입력하세요.')
			textarea#db-list(rows=20, cols=100)
			button#db-ok 추가
