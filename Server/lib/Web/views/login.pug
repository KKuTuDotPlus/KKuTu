extends layout

block Subject
	title 끄투닷플러스 - 글자에 즐거움을 더하다.

block CSS
	link(rel='stylesheet', href='/css/in_game_kkutu.css')

block Middle
	body
		span#locale= JSON.stringify(LANG)
		//볕뉘 수정 구문삭제(30)
		div.login-with= locals.text ? L(locals.text) : L('loginWith')
		//볕뉘 수정
		each val in loginList
			a(href="/login/" + val.vendor)
				button(style="color: " + val.fontColor + "; background-color: " + val.color + ";")
					div#login-name=L(val.displayName)
					div#login-icon(style="background-image: url(/img/auth/" + val.vendor + ".png);")
		//볕뉘 수정 끝
		div.login-legal!= L('loginLegal')